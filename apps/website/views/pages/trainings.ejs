<%- include('../partials/header') %>

<!-- Immersive Hero (About-style constellation) -->
<section class="abt-hero" id="trainHero">
    <div class="abt-hero__canvas">
        <svg class="abt-hero__net" viewBox="0 0 1400 700" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <defs>
                <radialGradient id="ng-train" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="rgba(124,58,237,0.7)"/><stop offset="100%" stop-color="rgba(124,58,237,0)"/></radialGradient>
                <filter id="gl-train"><feGaussianBlur stdDeviation="4" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
            </defs>
            <g stroke="rgba(124,58,237,0.12)" stroke-width="0.8" fill="none">
                <path class="svg-draw-line" d="M0,350 C200,100 500,500 700,300 S1100,100 1400,350"/>
                <path class="svg-draw-line" d="M0,450 C300,200 600,600 900,350 S1200,150 1400,400" style="animation-delay:.5s"/>
                <path class="svg-draw-line" d="M100,600 C350,300 650,500 900,250 S1150,400 1400,200" style="animation-delay:1s"/>
            </g>
            <g filter="url(#gl-train)">
                <circle cx="200" cy="220" r="3" fill="url(#ng-train)" class="svg-node--breathe"/>
                <circle cx="500" cy="400" r="4" fill="url(#ng-train)" class="svg-node--breathe" style="animation-delay:1s"/>
                <circle cx="700" cy="300" r="5" fill="url(#ng-train)" class="svg-node--breathe" style="animation-delay:2s"/>
                <circle cx="1000" cy="180" r="3" fill="url(#ng-train)" class="svg-node--breathe" style="animation-delay:.5s"/>
                <circle cx="1200" cy="380" r="4" fill="url(#ng-train)" class="svg-node--breathe" style="animation-delay:1.5s"/>
                <circle cx="350" cy="500" r="3" fill="url(#ng-train)" class="svg-node--breathe" style="animation-delay:2.5s"/>
            </g>
        </svg>
        <div class="abt-hero__orb abt-hero__orb--a"></div>
        <div class="abt-hero__orb abt-hero__orb--b"></div>
        <div class="abt-hero__orb abt-hero__orb--c"></div>
    </div>
    <div class="container abt-hero__inner" style="display:flex;justify-content:center;">
        <div class="abt-hero__content reveal" style="text-align:center;max-width:800px;">
            <p class="abt-hero__kicker" data-editable="true" data-model="Page" data-id="<%= page._id %>" data-field="hero_label" data-type="text"><%= page.hero_label %></p>
            <h1 class="abt-hero__h1" data-editable="true" data-model="Page" data-id="<%= page._id %>" data-field="hero_title" data-type="html"><%- page.hero_title %></h1>
            <p class="abt-hero__sub" data-editable="true" data-model="Page" data-id="<%= page._id %>" data-field="hero_subtitle" data-type="text"><%= page.hero_subtitle %></p>
        </div>
    </div>
    <div class="abt-hero__scroll-cue"><div class="scroll-mouse"></div></div>
</section>

<!-- Why Train With Us -->
<% const valueProps=(sections['training-value'] || []); %>
<% if (valueProps.length) { %>
<section class="editorial-trainings-values" aria-label="Why train with X DOT AI">
    <div class="container">
        <h2 class="editorial-section-title" data-animate="fade-up">Why Train with <span class="text-gradient">X DOT AI?</span></h2>
        <div class="editorial-values-grid">
            <% valueProps.forEach((v, i) => { %>
                <div class="editorial-value-card glass-card" data-animate="fade-up" style="--delay: <%= i * 0.1 %>s">
                    <div class="editorial-value-glow"></div>
                    <span class="editorial-value-icon"><%- v.icon %></span>
                    <h3><%= v.title %></h3>
                    <p><%= v.description %></p>
                </div>
            <% }) %>
        </div>
    </div>
</section>
<% } %>

<!-- Specialized Training Categories -->
<% const categories=(sections['training-category'] || []); %>
<% if (categories.length) { %>
<section class="editorial-trainings-programs" aria-label="Specialized Training Programs">
    <div class="container">
        <div class="editorial-programs-header" data-animate="fade-up">
            <h2 class="editorial-section-title">Specialized <span class="text-gradient">Programs</span></h2>
            <p class="editorial-section-subtitle">Industry-focused AI workshops tailored for your creative domain.</p>
        </div>
        
        <div class="editorial-programs-grid">
            <% categories.forEach((cat, i) => { %>
                <article class="editorial-program-card" data-animate="fade-up" style="--delay: <%= i * 0.1 %>s">
                    <div class="editorial-program-content">
                        <span class="editorial-program-icon"><%- cat.icon %></span>
                        <h3 class="editorial-program-title"><%= cat.title %></h3>
                        <p class="editorial-program-desc"><%= cat.description %></p>
                        <a href="/contact" class="editorial-link-magnetic magnetic-btn"><span>Enquire Now →</span></a>
                    </div>
                </article>
            <% }) %>
        </div>
    </div>
</section>
<% } %>

<!-- Who Are the Trainings For? -->
<section class="editorial-audience" aria-label="Who are the trainings for">
    <div class="container">
        <div class="editorial-audience-split">
            <div class="editorial-audience-content" data-animate="fade-left">
                <h2 class="editorial-section-title text-left">The <span class="text-gradient">Audience</span></h2>
                <div class="editorial-audience-text">
                    <p>Our trainings are designed for everyone — students, freelancers, professionals, or businesses — anyone who wants to integrate AI into fashion, advertising, film making, or marketing.</p>
                    <p>We don't just teach prompts; we teach systems thinking. The goal is to build sustainable creative pipelines that multiply your inherent capabilities.</p>
                </div>
                <ul class="editorial-audience-list">
                    <li><span class="bullet"></span> Students</li>
                    <li><span class="bullet"></span> Freelancers</li>
                    <li><span class="bullet"></span> Creative Professionals</li>
                    <li><span class="bullet"></span> Enterprises & Agencies</li>
                </ul>
            </div>
            <div class="editorial-audience-visual" data-animate="fade-right">
                <div class="editorial-audience-image-wrapper glass-card">
                    <img src="/images/training-target-audience.png" alt="AI Education and Empowerment" class="editorial-audience-img">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FAQ Accordion -->
<% const faqs=(sections['training-faq'] || []); %>
<% if (faqs.length) { %>
<section class="editorial-faq-section" aria-label="Frequently Asked Questions">
    <div class="container container-narrow">
        <h2 class="editorial-section-title text-center" data-animate="fade-up">Frequently Asked <span class="text-gradient">Questions</span></h2>
        <div class="editorial-faq-list">
            <% faqs.forEach((faq, i) => { %>
                <details class="editorial-faq-item" id="training-faq-<%= i %>" data-animate="fade-up" style="--delay: <%= i * 0.1 %>s">
                    <summary class="editorial-faq-question">
                        <span><%= faq.title %></span>
                        <span class="editorial-faq-toggle"></span>
                    </summary>
                    <div class="editorial-faq-answer">
                        <p><%= faq.description %></p>
                    </div>
                </details>
            <% }) %>
        </div>
    </div>
</section>
<% } %>

<!-- Registration CTA -->
<section class="editorial-cta">
    <div class="editorial-cta__bg"></div>
    <div class="container editorial-cta__content" data-animate="fade-up">
        <h2 class="editorial-cta__title">Learn with <span class="text-gradient">X DOT AI</span></h2>
        <p class="editorial-cta__desc">Ready to upgrade your creative workflow with models and systems? Let's build your AI capabilities.</p>
        <div class="editorial-cta__actions">
            <a href="/contact" class="btn btn-primary btn-large magnetic-btn"><span>Register Interest →</span></a>
            <a href="/portfolio" class="btn btn-outline btn-large magnetic-btn"><span>View Our Work</span></a>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>