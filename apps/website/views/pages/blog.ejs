<%- include('../partials/header') %>

<!-- Immersive Hero (About-style constellation) -->
<section class="abt-hero" id="blogHero">
    <div class="abt-hero__canvas">
        <svg class="abt-hero__net" viewBox="0 0 1400 700" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <defs>
                <radialGradient id="ng-blog" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="rgba(124,58,237,0.7)"/><stop offset="100%" stop-color="rgba(124,58,237,0)"/></radialGradient>
                <filter id="gl-blog"><feGaussianBlur stdDeviation="4" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
            </defs>
            <g stroke="rgba(124,58,237,0.12)" stroke-width="0.8" fill="none">
                <path class="svg-draw-line" d="M0,350 C200,100 500,500 700,300 S1100,100 1400,350"/>
                <path class="svg-draw-line" d="M0,450 C300,200 600,600 900,350 S1200,150 1400,400" style="animation-delay:.5s"/>
                <path class="svg-draw-line" d="M100,600 C350,300 650,500 900,250 S1150,400 1400,200" style="animation-delay:1s"/>
            </g>
            <g filter="url(#gl-blog)">
                <circle cx="200" cy="220" r="3" fill="url(#ng-blog)" class="svg-node--breathe"/>
                <circle cx="500" cy="400" r="4" fill="url(#ng-blog)" class="svg-node--breathe" style="animation-delay:1s"/>
                <circle cx="700" cy="300" r="5" fill="url(#ng-blog)" class="svg-node--breathe" style="animation-delay:2s"/>
                <circle cx="1000" cy="180" r="3" fill="url(#ng-blog)" class="svg-node--breathe" style="animation-delay:.5s"/>
                <circle cx="1200" cy="380" r="4" fill="url(#ng-blog)" class="svg-node--breathe" style="animation-delay:1.5s"/>
                <circle cx="350" cy="500" r="3" fill="url(#ng-blog)" class="svg-node--breathe" style="animation-delay:2.5s"/>
            </g>
        </svg>
        <div class="abt-hero__orb abt-hero__orb--a"></div>
        <div class="abt-hero__orb abt-hero__orb--b"></div>
        <div class="abt-hero__orb abt-hero__orb--c"></div>
    </div>
    <div class="container abt-hero__inner" style="display:flex;justify-content:center;">
        <div class="abt-hero__content reveal" style="text-align:center;max-width:800px;">
            <p class="abt-hero__kicker"><%= page.hero_label || 'Journal' %></p>
            <h1 class="abt-hero__h1"><%- page.hero_title || 'Latest <span class="text-gradient">Writings</span>' %></h1>
            <p class="abt-hero__sub"><%= page.hero_subtitle || 'Thoughts, tutorials, and explorations on generative AI.' %></p>
        </div>
    </div>
    <div class="abt-hero__scroll-cue"><div class="scroll-mouse"></div></div>
</section>

<!-- Category Filter -->
<section class="blog-filter-section" style="background: var(--bg-main); padding-top: 2rem;">
    <div class="container">
        <div class="editorial-filters">
            <a href="/blogs" class="editorial-filter-btn <%= !currentCategory ? 'active' : '' %>">All Posts</a>
            <% categories.forEach(cat=> { %>
                <a href="/blogs?category=<%= encodeURIComponent(cat.name) %>"
                    class="editorial-filter-btn <%= currentCategory === cat.name ? 'active' : '' %>">
                    <%= cat.name %>
                </a>
            <% }) %>
        </div>
        <p class="editorial-filter-desc">
            <%= totalPosts %> post<%= totalPosts !== 1 ? 's' : '' %> found
        </p>
    </div>
</section>

<!-- Magazine Grid -->
<section class="editorial-magazine" aria-label="Blog posts" style="padding-top: 2rem;">
    <div class="container">
        <% if (posts.length === 0) { %>
            <div class="editorial-empty">
                <p style="font-size:3rem;margin-bottom:1rem;">📝</p>
                <h2 style="color:var(--text-primary);margin-bottom:0.5rem;">No posts yet</h2>
                <p style="color:var(--text-secondary);">Check back soon for the latest insights.</p>
            </div>
        <% } else { %>
            <div class="editorial-magazine-grid">
                <% posts.forEach((post, idx) => { %>
                    <article class="editorial-article-card <%= idx === 0 ? 'editorial-article-card--featured' : '' %>" data-animate="fade-up" style="--delay: <%= idx * 0.1 %>s">
                        <div class="editorial-article__media">
                            <% if (post.featured_image) { %>
                                <img src="<%= post.featured_image %>" alt="<%= post.featured_image_alt || post.title %>" class="editorial-article__img" loading="lazy">
                            <% } else { %>
                                <img src="/images/portfolio-fallback.png" alt="Blog Post Placeholder" class="editorial-article__img">
                            <% } %>
                            <div class="editorial-article__overlay"></div>
                        </div>
                        <div class="editorial-article__content">
                            <div class="editorial-article__meta">
                                <% if (post.category) { %>
                                    <span class="editorial-article__tag"><%= post.category %></span>
                                <% } %>
                                <span class="editorial-article__date">
                                    <%= new Date(post.published_at).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %>
                                </span>
                                <span>• <%= post.reading_time %> min read</span>
                            </div>
                            <h2 class="editorial-article__title">
                                <%= post.title %>
                            </h2>
                            <p class="editorial-article__desc">
                                <%= post.excerpt || '' %>
                            </p>
                            <a href="/blogs/<%= post.slug %>" class="editorial-link-magnetic magnetic-btn"><span>Read Post →</span></a>
                        </div>
                    </article>
                <% }) %>
            </div>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
                <nav class="blog-pagination" aria-label="Blog pagination" style="margin-top: 4rem;">
                    <% if (currentPage > 1) { %>
                        <a href="/blogs?page=<%= currentPage - 1 %><%= currentCategory ? '&category=' + encodeURIComponent(currentCategory) : '' %>"
                            class="blog-page-btn">← Previous</a>
                    <% } %>
                    <div class="blog-page-numbers">
                        <% for (let i=1; i <=totalPages; i++) { %>
                            <a href="/blogs?page=<%= i %><%= currentCategory ? '&category=' + encodeURIComponent(currentCategory) : '' %>"
                                class="blog-page-num <%= i === currentPage ? 'active' : '' %>">
                                <%= i %>
                            </a>
                        <% } %>
                    </div>
                    <% if (currentPage < totalPages) { %>
                        <a href="/blogs?page=<%= currentPage + 1 %><%= currentCategory ? '&category=' + encodeURIComponent(currentCategory) : '' %>"
                            class="blog-page-btn">Next →</a>
                    <% } %>
                </nav>
            <% } %>
        <% } %>
    </div>
</section>

<%- include('../partials/footer') %>